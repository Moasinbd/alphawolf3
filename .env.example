# ─────────────────────────────────────────────────────────────
# AlphaWolf 3.0v — Environment Configuration
# Copy to .env and fill in. NEVER commit .env
# ─────────────────────────────────────────────────────────────

# ── Broker Mode ────────────────────────────────────────────
# paper = simulated (no IB needed, Phase 1-6)
# live  = IB Gateway (requires IB credentials, Phase 7+)
BROKER_MODE=paper

# ── Trading Universe ───────────────────────────────────────
SYMBOLS=AAPL,TSLA,NVDA,SPY,QQQ

# ── Capital (paper mode) ───────────────────────────────────
INITIAL_CAPITAL=100000

# ── IB Gateway (Phase 7+ only) ─────────────────────────────
# Fill in after paper mode is validated
IB_USERNAME=
IB_PASSWORD=
IB_TRADING_MODE=paper
IB_PORT=4002
