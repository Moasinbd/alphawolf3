# ─────────────────────────────────────────────────────────────
# Interactive Brokers Credentials
# Copy to config/ib.env and fill in — NEVER commit ib.env
# ─────────────────────────────────────────────────────────────

# Your IBKR paper trading credentials
IB_USERNAME=your_ibkr_username
IB_PASSWORD=your_ibkr_password

# Trading mode: paper | live
IB_TRADING_MODE=paper

# IB Gateway API port
# paper → 4002
# live  → 4001
IB_PORT=4002
